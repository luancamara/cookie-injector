{
  "manifest_version": 3,
  "name": "Cookie Injector",
  "version": "1.0",
  "description": "Injeta cookies em qualquer domínio via chrome.cookies API",
  "permissions": ["cookies", "storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
